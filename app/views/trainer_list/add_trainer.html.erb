<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Trainer</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>trainer_list" class="float-right">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>
			<%= form_tag({action: 'create'}, multipart: :true, id: :myforms, class: "form-horizontal") do  %>
						<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>
            <input type="hidden" name="mid" id="mid" value="<% if @trainer %><%=@trainer.id%><% end %>"/>
			<input type="hidden" name="cur_trn_code" id="cur_trn_code" value="<% if @trainer %><%=@trainer.trn_code%><% end %>"/>

					<div class="form-body">
						
					   	<div class="form-group row">
					   <div class="col-md-2 mmb100 hidden">
						<div class="profile-img-wrap edit-img">
						<a href="" class="example-image-link" data-lightbox="example-1">
							<img src="" class="img-responsive img-thumbnail" name="item-img-output" id="item-img-output" />
						</a>
						<div class="fileupload" style="position: absolute; bottom: 0px; left: 2px; background: #fff; color: #000; padding: 0px 20px; border-radius: 0px;">
							<label class="custom-file-upload" style="margin: 0px;">
							<input type="file" accept=".jpg,.png,.jpeg" class="upload item-img file center-block" name="" id="" style="display: none;" />
							<p style="margin: 0 0 0px; font-size: 13px;" >Upload</p>
							</label>
						</div>
						</div>
					</div>
					<div class="col-md-10">
					<div class="form-group row">
					<label class="col-md-3">Code
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
										<input name="trn_code" id="trn_code"  type="text"  placeholder="Enter Code"
										autocomplete="off" maxlength="10" class="form-control" readonly required value="<% if @trainer%><%=@trainer.trn_code%><% else %><%=@Lastcode%><% end %>"/> 
					
					</div>
					<label class="col-md-3 age_calcualted">Date of Birth
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="trn_dob" id="trn_dob" type="text" placeholder="Select Date" autocomplete="off" maxlength="20" class="form-control" required value="<% if @trainer%><%=formatted_date(@trainer.trn_dob)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_dob'] %><% end %>"/>
					</div>
						
					</div>

					</div>

					<div class="form-group row">
					<label class="col-md-3">Name
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="trn_name" id="trn_name"  type="text"  placeholder="Enter Name"
					autocomplete="off" maxlength="50" class="form-control" required value="<% if @trainer%><%=@trainer.trn_name%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_name'] %><% end %>"/> 
					</div>
					<label class="col-md-3">Gender
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
						<select class="form-select select-height" required name="trn_gender" id="trn_gender">
							<option value="">Select...</option>
							<option value="M" <% if @trainer && @trainer.trn_gender.to_s == 'M'%>selected<% end %>>Male</option>
							<option value="F"  <% if @trainer && @trainer.trn_gender.to_s == 'F'%>selected<% end %>>Female</option>
							<option value="Oth"  <% if @trainer && @trainer.trn_gender.to_s == 'Oth'%>selected<% end %>>Other</option>
						
						</select>
					</div>

					</div>

						<div class="form-group row">
						<label class="col-md-3">Joining Date
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="trn_join_date" id="trn_join_date" type="text" placeholder="Select Join Date" autocomplete="off" maxlength="20" class="form-control" value="<% if @trainer%><%=formatted_date(@trainer.trn_join_date)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_join_date'] %><% end %>"/>
					</div></div>
					<label class="col-md-3">Leaving Date
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="trn_leave_date" id="trn_leave_date" type="text" placeholder="Select Leave Date" autocomplete="off" maxlength="20" class="form-control" value="<% if @trainer%><%=formatted_date(@trainer.trn_leave_date)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_leave_date'] %><% end %>"/>
					</div>
					</div>
					
					</div>



					</div>
					</div>
									
									

				
					<div class="mdl-tabs mdl-js-tabs">
					<div class="mdl-tabs__tab-bar tab-left-side">
						<a href="#student_detail" class="mdl-tabs__tab is-active">Basic Details</a>
						
					</div>

					<div class="mdl-tabs__panel is-active p-t-20" id="student_detail">
					<div class="card-box">
					<div class="card-body ">
					<div class="form-group row">
					
					
				
				
				
				</div>
					<div class="form-group row">
				
					<label class="col-md-3">Aadhaar No.
					</label>
					<div class="col-md-3">
					<input name="trn_aadhaar" id="trn_aadhaar" onkeypress="return isNumberMyKeys(event);" type="text"  placeholder="Enter Aadhaar No"
					autocomplete="off" maxlength="12" class="form-control"  value="<% if @trainer%><%=@trainer.trn_aadhaar%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_aadhaar'] %><% end %>"/> 
					</div>
						<label class="col-md-3">Email Id
					</label>
					<div class="col-md-3">
					<div class="input-group">
						<span class="input-group-addon iconinput-pd"><i class="fa fa-envelope"></i></span>
						<input name="trn_email" id="trn_email"  type="email"  placeholder="Enter Email Id"
					autocomplete="off" maxlength="50" class="form-control" onchange="check_email_validation(this.value,'trn_email');" value="<% if @trainer%><%=@trainer.trn_email%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_email'] %><% end %>"/>
					</div>
					</div>
					</div>

					
					<div class="form-group row">
					<label class="col-md-3">Contact No.
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-phone"></i></span>
					<input name="trn_contact" id="trn_contact" onkeypress="return isNumberMyKeys(event);"  type="text"  placeholder="Enter Contact No."
					autocomplete="off" maxlength="10" class="form-control" required value="<% if @trainer%><%=@trainer.trn_contact%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_contact'] %><% end %>"/> 
					</div>
					
					</div>

					<label class="col-md-3">Speciality
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="trn_speciality" id="trn_speciality"  type="text"  placeholder="Eg: Strength, Yoga, Weight Loss"
					autocomplete="off" maxlength="200" class="form-control" required
					value="<% if @trainer%><%=@trainer.trn_speciality%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_speciality'] %><% end %>"/> 
					</div>
					</div>

						<div class="form-group row">
				
					<label class="col-md-3">Address 1
					</label>
					<div class="col-md-3">
					<input name="trn_addr1" id="trn_addr1"  type="text"  placeholder="Enter Address 1"
					autocomplete="off" maxlength="150" class="form-control"  value="<% if @trainer%><%=@trainer.trn_addr1%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_addr1'] %><% end %>"/> 
					</div>

					<label class="col-md-3">Experience (Years)
					</label>
					<div class="col-md-3">
					<input name="trn_experience_years" id="trn_experience_years" onkeypress="return isNumberMyKeys(event);" type="text"
					placeholder="Enter Years"
					autocomplete="off" maxlength="3" class="form-control"
					value="<% if @trainer%><%=@trainer.trn_experience_years%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_experience_years'] %><% end %>"/> 
					</div>
					</div>

						<div class="form-group row">
				
					<label class="col-md-3">Address 2
					
					</label>
					<div class="col-md-3">
					<input name="trn_addr2" id="trn_addr2"  type="text"  placeholder="Enter Address 2"
					autocomplete="off" maxlength="150" class="form-control" value="<% if @trainer%><%=@trainer.trn_addr2%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_addr2'] %><% end %>"/> 
					</div>

					<label class="col-md-3">Certification
					</label>
					<div class="col-md-3">
					<input name="trn_certification" id="trn_certification" type="text"
					placeholder="Eg: ACE, K11, ISSA"
					autocomplete="off" maxlength="200" class="form-control"
					value="<% if @trainer%><%=@trainer.trn_certification%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_certification'] %><% end %>"/> 
					</div>
	
					</div>

				<div class="form-group row">

				<label class="col-md-3">Salary Type
				<span class="required"> * </span>
				</label>
				<div class="col-md-3">
				<select class="form-select select-height" required name="trn_salary_type" id="trn_salary_type">
				<option value="">Select...</option>
				<option value="MONTHLY" <% if @trainer && @trainer.trn_salary_type.to_s == 'MONTHLY'%>selected<% end %>>Monthly</option>
				<option value="PER_SESSION" <% if @trainer && @trainer.trn_salary_type.to_s == 'PER_SESSION'%>selected<% end %>>Per Session</option>
				<option value="COMMISSION" <% if @trainer && @trainer.trn_salary_type.to_s == 'COMMISSION'%>selected<% end %>>Commission</option>
				</select>
				</div>

				<label class="col-md-3">Salary Amount
				<span class="required"> * </span>
				</label>
				<div class="col-md-3">
				<input name="trn_salary_amount" id="trn_salary_amount" onkeypress="return isNumberMyKeys(event);" type="text"
				placeholder="Enter Amount"
				autocomplete="off" maxlength="8" class="form-control" required
				value="<% if @trainer%><%=@trainer.trn_salary_amount%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['trn_salary_amount'] %><% end %>"/> 
				</div>

				</div>

				<div class="form-group row">

				<label class="col-md-3">Status
				<span class="required"> * </span>
				</label>
				<div class="col-md-3">
				<select class="form-select select-height" required name="trn_status" id="trn_status">
				<option value="">Select...</option>
				<option value="ACTIVE" <% if @trainer && @trainer.trn_status.to_s == 'ACTIVE'%>selected<% end %>>Active</option>
				<option value="INACTIVE" <% if @trainer && @trainer.trn_status.to_s == 'INACTIVE'%>selected<% end %>>Inactive</option>
				</select>
				</div>

				</div>

					
					</div>
				<div class="form-group form-button text-center  m-b-10" style="margin-top: 50px;">
							<button type="button" onclick="process_save_student_details();"
							class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 m-r-20 btn-circle btn-primary">SUBMIT</button>
								<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
							<a href="<%=root_url%>trainer_list">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>


					<div class="mdl-tabs__panel p-t-20" id="other_details">	</div>

					</div>
									

							
					</div>
				
			</div>
		</div>
	</div>
</div>
									        <input type="hidden" id="currImage" value=""/>

				<div class="modal fade" id="cropImagePop" tabindex="-1" role="dialog" aria-labelledby="myModalLabel" aria-hidden="true">
		<div class="modal-dialog">
		<div class="modal-content" style="height: 500px;">
		<div class="modal-header">
		<button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
		<h4 class="modal-title" id="myModalLabel">
		<?=multiLanguage( "Edit Foto" , "Edit Photo" )?></h4>
		</div>
		<div class="modal-body m-b-20">
		<div id="upload-demo" class="center-block"></div>
		</div>
		<div class="modal-footer " >
		<button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Close</button>
		<button type="button" id="cropImageBtn" class="btn btn-primary">Crop</button>
		</div>
		</div>
		</div>
		</div>
        </form>
				<% end %>
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>