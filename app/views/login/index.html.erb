<!-- Main Wrapper -->
<main class="card">
<section class="hero">
  <div class="brand">
    <div class="brand-mark">S</div>
    <div>
      <div class="brand-name">SPINE INFRATECH</div>
      <div class="brand-sub">FITNESS · STRENGTH · DISCIPLINE</div>
    </div>
  </div>
  <div class="hero-copy">
    <span class="eyebrow">Members Portal</span>
    <h1 class="hero-title">UNLEASH YOUR<br><span class="accent">STRENGTH.</span></h1>
    <p class="hero-lede">Track workouts, manage memberships and keep your gym running at peak performance — all from one dashboard.</p>
  </div>
</section>
<section class="form-wrap">
  <div class="form-inner">
    <div class="welcome">Welcome Back</div>
    <h2 class="form-title">Login to continue</h2>
    <p class="form-sub">Sign in to your SPINE INFRATECH dashboard.</p>

    <input type="hidden" id="rootXPath" value="<%= root_url %>" />

    <%= form_tag({:action => 'create'}, :multipart => true, :id => :myforms, :autocomplete => "off") do %>

      <% if flash[:error] %>
        <div class="alert alert-danger" id="successXMessage">
          <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
          <%= flash[:error] %>
        </div>
      <% end %>

      <div class="field">
        <label for="userName">Username</label>
        <div class="control">
          <span class="icon"><i class="fa-solid fa-user"></i></span>
          <input name="userName" id="userName" type="text" placeholder="Enter your username" />
        </div>
      </div>

      <div class="field">
        <label for="userPassword">Password</label>
        <div class="control">
          <span class="icon"><i class="fa-solid fa-lock"></i></span>
          <input name="userPassword" id="userPassword" type="password" placeholder="••••••••" />
          <button type="button" class="toggle-pass" onclick="var i=document.getElementById('userPassword');i.type=i.type==='password'?'text':'password';">
            <i class="fa-regular fa-eye"></i>
          </button>
        </div>
      </div>

      <div class="row-between">
        <label class="remember"><input type="checkbox" /> Remember me</label>
        <a class="forgot" href="#">Forgot password?</a>
      </div>

      <button type="submit" class="btn-login" onclick="user_logins();">
        <i class="fa-solid fa-dumbbell"></i> Login
      </button>

      <div class="divider">SECURE ACCESS</div>

      <div class="foot">
        <span>Powered by <a href="https://github.com/imlakshay08" target="_blank">Lakshay Tyagi</a></span>
        <span>© 2026 SPINE INFRATECH</span>
      </div>

    <% end %>
  </div>
</section>
</main>
<script>
  document.getElementById('myforms').addEventListener('submit', function() {
    var btn = document.querySelector('.btn-login');
    btn.disabled = true;
    btn.innerHTML = '<span class="btn-spinner"></span> LOGGING IN...';
  });
</script>
