<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Issue Amount</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                                        <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-1">Search</label>
                    <div class="col-sm-12 col-md-4">  <input type="text" class="form-control" name="issue_amount" id="issue_amount"  autocomplete="off" placeholder="Enter "  value="<% if @issue_amount_search %><%=@issue_amount_search%><% end %>"/></div>
                    
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_issue_amount();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-2">  
                    <a href="<%=root_url%>issue_amount/referesh_issue_amount" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>issue_amount/add_issue_amount"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Issue Amount</button> </a>
                      </div> 
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>

                      </div>

                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>issue_amount/1_prt_issue_amount.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10 " style="float:right;">PDF</button> </a>
                      </div>
                      </div>
											
												<table 
                        class="table table-striped table-bordered table-hover "
                        id="example4">
													<thead>
														<tr>
                            <th>S.No</th>
                            <th>Issue No</th>
                            <th>Date</th>
                            <th>Staff</th>
                            <th>Type</th>
                            <th>Amount</th>
														</tr>
													</thead>
													<tbody>
                                         <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @issue_amount && @issue_amount.length>0 %>
                            <% @issue_amount.each do |issue| %>    
  
                          <%
                          	staffobj = get_staff_detail(issue.ia_staff_id)
                            if staffobj
                               staffname = staffobj.stf_name
                            end
                          %>

														<tr  class="odd gradeX">
															<td><%= i %></td>
                              <td><%=issue.ia_code%></td>
                              <td><%=formatted_date(issue.ia_date)%></td>
                              <td><%=staffname%></td>
                              <td><% if issue.ia_type == 'I'%>Issue<%elsif issue.ia_type == 'R'%>Return<%end%></td>
                              <td><%=issue.ia_amount%></td>

                          </tr>
                          <% i += 1 %>
                            <% end %>
                            <% end %>
													</tbody>
												</table>
											
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

