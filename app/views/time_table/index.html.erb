<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Time Table</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
		
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>
			<%= form_tag({action: 'index'}, multipart: :true, id: :myforms, class: "form-horizontal") do  %>
						<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>
			            <input type="hidden" name="mid" id="mid" value="<%if @time_table%><%=@time_table.id%><% end %>"/>
			<input type="hidden" class="form-control-sm" name="timetableid" id="timetableid" value="">

					<div class="form-body">
					<div class="row">
	<div class="col-md-8 col-sm-8">

							<div class="form-group row">
						<label class="col-md-2">Year
					<span class="required"> * </span>
				</label>
				<div class="col-md-4">
					<select class="form-select select-height"  name="tt_year" id="tt_year" onchange="get_time_table_sheet_list();">
							<option value="">Select...</option>
							<option value="2024"<% if @time_table && @time_table.tt_year.to_s == '2024'%>selected<% end %>>2024-2025</option>
							<option value="2025"<% if @time_table && @time_table.tt_year.to_s == '2025'%>selected<% end %>>2025-2026</option>
							<option value="2026"<% if @time_table && @time_table.tt_year.to_s == '2026'%>selected<% end %>>2026-2027</option>
							<option value="2027"<% if @time_table && @time_table.tt_year.to_s == '2027'%>selected<% end %>>2027-2028</option>
							<option value="2028"<% if @time_table && @time_table.tt_year.to_s == '2028'%>selected<% end %>>2028-2029</option>
							<option value="2029"<% if @time_table && @time_table.tt_year.to_s == '2029'%>selected<% end %>>2029-2030</option>
							<option value="2030"<% if @time_table && @time_table.tt_year.to_s == '2030'%>selected<% end %>>2030-2031</option>

						</select>
				</div>
			
	</div>

	<div class="form-group row">

	<label class="col-md-2">Course
					<span class="required"> * </span>
				</label>
				<div class="col-md-4">
					<select class="form-select select-height"  name="tt_course" id="tt_course" onchange="updateSemesters();" >
							<option value="">Select...</option>
							<%
                        if @CourseList && @CourseList.length>0
                            @CourseList.each do |course|
                    %>
                    <option value="<%=course.id%>" <% if @time_table && @time_table.tt_course.to_i == course.id.to_i %>selected<% elsif session[:sess_tt_course].to_s==course.id.to_i%>selected<% end %>><%=course.crse_descp%></option>
                    <%
                    end
                    end
                    %>
						</select>
				</div>
						<label class="col-md-3">Semester
					<span class="required"> * </span>
				</label>
				<div class="col-md-3">
					<select class="form-select select-height" required name="sub_sem" id="sub_sem" onchange="common_process_requested();">
						<option value="">Select...</option>
						
					</select>
				</div>

				

	</div>
					<div class="form-group row">
					<label class="col-md-2">Subject
						<span class="required"> * </span>
					</label>
					<div class="col-md-4">
						<select class="form-select select-height"  name="tt_subject" id="tt_subject" onchange="filter_time_table();fill_from_subject();">
							<option value="">Select...</option>
							
						</select>
					</div>
					
					<label class="col-md-3">Student Group
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
						<select class="form-select select-height"  name="tt_group" id="tt_group" >
							<option value="">Select...</option>
							
						</select>
					</div>
					</div>
				</div>

	<div class="col-md-4 col-sm-12">
			<div class="card mb-0" id="date-details-card" style="display: none;">
								<div class="card-body " style="font-size: 14px;">
								<label > This Time Table is valid from</label>
                          <div class="stat-item"  name="tt_dtp_fromdate" id="tt_dtp_fromdate">
										</div>
										<div class="stat-item"  name="" id="">
											to
										</div>
										<div class="stat-item"  name="tt_dtp_uptodate" id="tt_dtp_uptodate">
										</div>
								</div>
						</div>
	</div>
	</div>
					
<div class="form-group row mt-4">
					<div class="col-md-2 text-center" >
					Day <span class="required"> * </span><br/>
					<select class="form-select select-height"  name="tt_day" id="tt_day">
							<option value="">Select...</option>
							<option value="MON" <% if @time_table && @time_table.tt_day.to_s == 'MON'%>selected<% end %>>Monday</option>
							<option value="TUES" <% if @time_table && @time_table.tt_day.to_s == 'TUES'%>selected<% end %>>Tuesday</option>
							<option value="WED" <% if @time_table && @time_table.tt_day.to_s == 'WED'%>selected<% end %>>Wednesday</option>
							<option value="THURS" <% if @time_table && @time_table.tt_day.to_s == 'THURS'%>selected<% end %>>Thursday</option>
							<option value="FRI" <% if @time_table && @time_table.tt_day.to_s == 'FRI'%>selected<% end %>>Friday</option>
							
						</select>
				</div>
				
			<div class="col-md-2 text-center" >
			Period <span class="required"> * </span><br/>
			<select class="form-select select-height"   name="tt_period" id="tt_period">
							<option value="">Select...</option>
							<option value="1" <% if @time_table && @time_table.tt_period.to_s == '1'%>selected<% end %>>1</option>
							<option value="2" <% if @time_table && @time_table.tt_period.to_s == '2'%>selected<% end %>>2</option>
							<option value="3" <% if @time_table && @time_table.tt_period.to_s == '3'%>selected<% end %>>3</option>
							<option value="4" <% if @time_table && @time_table.tt_period.to_s == '4'%>selected<% end %>>4</option>
							<option value="5" <% if @time_table && @time_table.tt_period.to_s == '5'%>selected<% end %>>5</option>
							<option value="6" <% if @time_table && @time_table.tt_period.to_s == '6'%>selected<% end %>>6</option>
							<option value="7" <% if @time_table && @time_table.tt_period.to_s == '7'%>selected<% end %>>7</option>
							<option value="8" <% if @time_table && @time_table.tt_period.to_s == '8'%>selected<% end %>>8</option>
						
						</select>
			</div>
			<div class="col-md-3 text-center" >
			Faculty <span class="required"> * </span><br/>
				<select class="form-select select-height"   name="tt_faculty" id="tt_faculty">
							<option value="">Select...</option>
								<%
                        if @Faculty && @Faculty.length>0
                            @Faculty.each do |faculty|
                    %>
                    <option value="<%=faculty.id%>" <% if @time_table && @time_table.tt_faculty.to_i == faculty.id.to_i %>selected<% elsif session[:sess_tt_faculty].to_s==faculty.id.to_i%>selected<% end %>><%=faculty.fclty_name%></option>
                    <%
                    end
                    end
                    %>
						</select>
			</div>
			
			<div class="col-md-2" >
			
			<button type="button" class="btn btn-circle btn-info mt-4" onclick="save_time_table();">Save</button>
			<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
			</div>
				</div>
						<div class="table-scrollable">
												<table class="timetable table" >
													<thead>
														<tr>
															<th width="10%" class=>Day</th>
															<th class="groupbg" width="5%">Gr.</th>
															<th width="10%">1</th>
															<th width="10%">2</th>
															<th width="10%">3</th>
															<th width="10%">4</th>
															<th width="5%"></th>
															<th class="groupbg" width="5%">Gr.</th>
															<th width="10%">5</th>
															<th width="10%">6</th>
															<th width="10%">7</th>
															<th width="10%">8</th>
															
														</tr>
													</thead>
													<tbody id="process_time_table" >
													<tr> 
														 <td class="text-left" colspan="12">No Record(s) found.</td>
													</tr>  
											 
												
										</tbody>
												</table>
											</div>

							<div class="form-group form-button text-center  m-b-20" style="margin-top: 50px;">
							
								
							<a href="<%=root_url%>dashboard">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>
				</form>
				<% end %>
			</div>
		</div>
	</div>
</div>
					
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>