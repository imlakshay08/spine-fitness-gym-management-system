<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Members List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
          <div class="row">
          <div class="col-md-12">
            <div class="tabbable-line">
              <ul class="nav customtab nav-tabs" role="tablist">
                <li class="nav-item"><a href="#tab1" class="nav-link active"
                    data-bs-toggle="tab">List
                    View</a></li>
              </ul>
              <div class="tab-content">
									<div class="tab-pane active fontawesome-demo" id="tab1">
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>

                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-2">Name</label>
                    <div class="col-sm-12 col-md-3">  <input type="text" class="form-control" name="member_list" id="member_list"  autocomplete="off" placeholder="Enter Member Name"  value="<% if @member_list_search %><%=@member_list_search%><% end %>"/></div>
                    
                  
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_member_list();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-6 ">  
                    <a href="<%=root_url%>member_list/referesh_member_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>member_list/add_member"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Member</button> </a>
                      </div>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>
                      </div>
 
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>member_list/1_prt_member_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">PDF</button> </a>
                      </div>
 
                      </div>
										
                      <table
                      class="table table-striped table-bordered table-hover "
                      id="example4" >
                      <thead>
                        <tr>
                          <th>S.No</th>
                          <th>Member Code</th>
                          <th>Member Name </th>
                          <th>Gender</th>
                          <th>Contact No.</th>
                          <th> Action </th>
                        </tr>
                      </thead>
                      <tbody>
                      <% 
                       pagestart = params[:page].present? ? params[:page].to_i : 1
                         i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1
                      if @member_list && @member_list.length>0 
                             @member_list.each do |member| %> 
                        <tr class="odd gradeX">
                        <td class="left"><%= i %></td>
                        <td class="left"><%= member.mmbr_code%></td>
                          <td class="left"><%= member.mmbr_name %></td>
                          <%if member.mmbr_gender == ''%>
                          <td class="left"></td>
                          <%elsif member.mmbr_gender == 'M'%>
                          <td class="left">Male</td>
                          <%elsif member.mmbr_gender == 'F'%>
                          <td class="left">Female</td>
                          <%elsif member.mmbr_gender == 'Oth'%>
                          <td class="left">Other</td>
                          <%end%>
                          <td class="left"><%= member.mmbr_contact %></td>
                          <td> 
                            <a href="<%= root_url %>member_list/add_member/<%= member.id %>" class="tblEditBtn">
                              <i class="fa fa-pencil"></i>
                            </a> 
                             
                            <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>member_list/<%= member.id %>/deletes')">
                              <i class="fa fa-trash-o"></i>
                            </a> 
                            <% latest = @latest_subscription_hash[member.id] %>
                        <% if latest.nil? || latest.ms_end_date < Date.today %>
                          <a href="<%= root_url %>member_subscriptions/add_member_subscriptions?renew=1&member_id=<%=member.id%>"
                            class="btn btn-warning btn-xs">
                            Renew
                          </a>
                        <% end %>
                          </td>
                        </tr>
                        <% i += 1 %>
                            <% end %>
                            <% end %>
                      </tbody>
                    </table>
										
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
                </div>
                <div class="tab-pane" id="tab2">
										<div class="row">
								
											<div class="col-md-4">
												<div class="card card-box">
													<div class="card-body no-padding ">
														<div class="doctor-profile">
                          
															<img src="" class="doctor-pic img-thumbnail"
																alt="">
                            <img src="<%= root_url %>images/no-image.jpg" class="doctor-pic img-responsive img-thumbnail" alt="">
															<div class="profile-usertitle">
																<div class="doctor-name"></div>
																
                          <div class="name-center"></div>
                          <div class="name-center">Male</div>
                          <div class="name-center">Female</div>
                          <div class="name-center">Other</div>
                                 
															</div>
															<p><br /></p>
															<div>
																<p><i class="fa fa-phone"></i><a
																		href="tel:(123)456-7890"> </a></p>
															</div>
															<div class="profile-userbuttons">
																<a href="<%=root_url%>faculty_list/add_faculty"
																	class="btn btn-circle deepPink-bgcolor btn-sm">Edit</a>
								
															</div>
														</div>
													</div>
												</div>
											</div>
											
										</div>
								
									</div>
								</div>

        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

