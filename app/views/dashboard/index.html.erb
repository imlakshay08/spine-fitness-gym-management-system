<%
begin
%>
<div class="page-wrapper">
<%= render "layouts/header" %>

<div class="page-container">
  <%= render "layouts/sidebar" %>

  <div class="page-content-wrapper">
    <div class="page-content">

      <div class="page-bar">
        <div class="page-title-breadcrumb">
          <div class="pull-left">
            <div class="page-title">Dashboard</div>
          </div>
          <%= render "layouts/breadcrumbs" %>
        </div>
      </div>

      <%= form_tag({ action: 'index' }, multipart: true, id: 'myForms') do %>
      <input type="hidden" id="rootXPath" value="<%= root_url %>">
      <input type="hidden" id="server_request" name="server_request" value="Y">

      <!-- ROW 1 : SUMMARY BOXES -->
      <div class="row">

        <!-- STOCK SUMMARY -->
        <div class="col-md-3 col-sm-12">
          <div class="card card-box">
            <div class="card-head">
              <header>Stock Summary</header>
            </div>

    <div class="card-body p-0" style="height:280px; overflow-y:auto;">
              <ul class="list-group">
                <% @stock_list.each do |stk| %>
                  <li class="list-group-item d-flex justify-content-between align-items-center">
                    <span><strong><%= stk.sl_name %></strong></span>
                    <span class="badge badge-info badge-pill"><%= get_current_stock(stk.id) %></span>
                  </li>
                <% end %>
              </ul>
            </div>
          </div>
        </div>

        <div class="row mb-4">

          <div class="col-md-3">
            <div class="card text-center">
              <div class="card-body">
                <h4><%= @active_count %></h4>
                <p>Active Subscriptions</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card text-center">
              <div class="card-body">
                <h4><%= @expiring_count %></h4>
                <p>Expiring Subscriptions(7 Days)</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card text-center">
              <div class="card-body">
                <h4><%= @expired_count %></h4>
                <p>Expired Subscriptions</p>
              </div>
            </div>
          </div>

          <div class="col-md-3">
            <div class="card text-center bg-success text-white">
              <div class="card-body">
                <h4>₹ <%= @today_collection %></h4>
                <p>Today's Collection</p>
              </div>
            </div>
          </div>

        </div>

        <!-- EXPIRED SUBSCRIPTIONS -->
<div class="col-md-4">
  <div class="card h-100">
    <div class="card-head">
      <header>Expired Subscriptions</header>
    </div>

    <div class="card-body p-0" style="height:280px; overflow-y:auto;">
      <ul class="list-group list-group-flush">
        <% @expired_subs.each do |sub| %>
          <% mem = get_member_detail(sub.ms_member_id) %>
          <li class="list-group-item d-flex justify-content-between">
            <span><%= mem&.mmbr_name || "Unknown Member" %>(<%= mem&.mmbr_contact%>)</span>
            <span class="text-danger">
              <%= sub.ms_end_date.strftime("%d-%b") %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<div class="col-md-4">
  <div class="card h-100">
    <div class="card-head">
      <header>Expiring Soon Subscriptions</header>
    </div>

    <div class="card-body p-0" style="height:280px; overflow-y:auto;">
      <ul class="list-group list-group-flush">
        <% @expiring_subs.each do |sub| %>
          <% mem = get_member_detail(sub.ms_member_id) %>
          <li class="list-group-item d-flex justify-content-between">
            <span><%= mem&.mmbr_name || "Unknown Member" %>(<%= mem&.mmbr_contact%>)</span>
            <span class="text-warning">
              <%= sub.ms_end_date.strftime("%d-%b") %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<div class="col-md-4">
  <div class="card h-100">
    <div class="card-head">
      <header>Active Subscriptions</header>
    </div>

    <div class="card-body p-0" style="height:280px; overflow-y:auto;">
      <ul class="list-group list-group-flush">
        <% @active_subs.each do |sub| %>
          <% mem = get_member_detail(sub.ms_member_id) %>
          <li class="list-group-item d-flex justify-content-between">
            <span><%= mem&.mmbr_name || "Unknown Member" %>(<%= mem&.mmbr_contact%>)</span>
            <span>
              <%= payment_status(sub) %> |
              <%= sub.ms_end_date.strftime("%d-%b") %>
            </span>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</div>

<div class="row mt-4">
  <div class="col-md-12">
    <div class="card">
      <div class="card-head"><header>Members With Due</header></div>
      <div class="card-body">
        <table class="table table-bordered">
          <thead>
            <tr>
              <th>Member(Contact)</th>
              <th>Plan</th>
              <th>Final Amount</th>
              <th>Paid</th>
              <th>Due</th>
            </tr>
          </thead>
          <tbody>
            <% @due_members.each do |sub| %>
              <% mem = get_member_detail(sub.ms_member_id) %>
              <%
              														planobj = get_plan_detail(sub.ms_plan_id)
                            if planobj
                               planname = planobj.plan_name
                            end
              %>
              <tr>
                <td><%= mem&.mmbr_name || "Unknown Member" %>(<%=mem&.mmbr_contact%>)</td>
                <td><%= planname %></td>
                <td>₹ <%= sub.ms_final_amount %></td>
                <td>₹ <%= total_paid(sub) %></td>
                <td class="text-danger">₹ <%= due_amount(sub) %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</div>


      <!-- ROW 2 : CALENDAR FULL-WIDTH -->
      <div class="row mt-4">
        <div class="col-md-12 col-sm-12">
          <div class="card">
            <div class="card-head"><header>Calendar</header></div>
            <div class="card-body">
              <div class="panel-body">
                <div id="calendar" class="has-toolbar"></div>
              </div>
            </div>
          </div>
        </div>
      </div>

      <% end %> <!-- form -->

    </div> <!-- page-content -->
  </div> <!-- wrapper -->
</div> <!-- container -->

<%
rescue => e
  message = "Error: #{e.message}"
end
%>

<%= message %>
