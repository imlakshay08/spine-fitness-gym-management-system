<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Members/Staff List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
          <div class="row">
          <div class="col-md-12">
            <div class="tabbable-line">
              <ul class="nav customtab nav-tabs" role="tablist">
                <li class="nav-item"><a href="#tab1" class="nav-link active"
                    data-bs-toggle="tab">List
                    View</a></li>
                <li class="nav-item"><a href="#tab2" class="nav-link" data-bs-toggle="tab">Grid
                    View</a></li>
              </ul>
              <div class="tab-content">
									<div class="tab-pane active fontawesome-demo" id="tab1">
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>

                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-2">Name</label>
                    <div class="col-sm-12 col-md-3">  <input type="text" class="form-control" name="faculty_list" id="faculty_list"  autocomplete="off" placeholder="Enter Employee Name"  value="<% if @faculty_list_search %><%=@faculty_list_search%><% end %>"/></div>
                    
                  
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_faculty_list();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-6 ">  
                    <a href="<%=root_url%>faculty_list/referesh_faculty_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>faculty_list/add_faculty"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Faculty</button> </a>
                      </div>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>
                      </div>
                      <% if @faculty_list && @faculty_list.length>0 %>
                        <% if @myPrintAld %>
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>faculty_list/1_prt_faculty_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">PDF</button> </a>
                      </div>
                      <% end %>
                      <% end %>
                      </div>
										
                      <table
                      class="table table-striped table-bordered table-hover "
                      id="example4" >
                      <thead>
                        <tr>
                          <th>S.No</th>
                          <th class="text-center">Image </th>
                          <th>Faculty Name </th>
                          <th>Gender</th>
                          <th>Date of Birth</th>
                          <th>Designation</th>
                          <th>Date of Joining</th>
                          <th> Action </th>
                        </tr>
                      </thead>
                      <tbody>
                      <% 
                       pagestart = params[:page].present? ? params[:page].to_i : 1
                         i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1
                      if @faculty_list && @faculty_list.length>0 
                             @faculty_list.each do |faculty| %> 
                        <tr class="odd gradeX">
                        <td class="left"><%= i %></td>
                        <td class="patient-img text-center">
                        <%  if
						image_url = "https://user.gadjian.com/static/images/personnel_boy.png"
						pullimgpath = "https://ihm-inqerp.b-cdn.net"
						
							compcode = faculty.fclty_compcode
							img_path = faculty.fclty_img.to_s
						image_url = "#{pullimgpath}/#{compcode}/faculty/#{img_path}"
						
					   %>
                        <div class="">
                         <a href="<%= image_url %>" class="example-image-link" data-lightbox="example-1"><img src="<%=image_url%>" title="<%=faculty.fclty_name%>"/></a>
                        <div>
                        <%else%>
                        N/A 
                        <%end%>
                        </td>  
                          <td class="left"><%= faculty.fclty_name %></td>
                          <%if faculty.fclty_gender == ''%>
                          <td class="left"></td>
                          <%elsif faculty.fclty_gender == 'M'%>
                          <td class="left">Male</td>
                          <%elsif faculty.fclty_gender == 'F'%>
                          <td class="left">Female</td>
                          <%elsif faculty.fclty_gender == 'Oth'%>
                          <td class="left">Other</td>
                          <%end%>
                          <td class="left"><%= formatted_date(faculty.fclty_dob) %></td>
                          <td class="left"><%= faculty.fclty_desig %></td>
                          <td class="left"><%= formatted_date(faculty.fclty_join_date) %></td>
                          <td> <% if @myEditAld %>
                            <a href="<%= root_url %>faculty_list/add_faculty/<%= faculty.id %>" class="tblEditBtn">
                              <i class="fa fa-pencil"></i>
                            </a> <% end %>
                             <% if @myDeletAld %>
                            <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>faculty_list/<%= faculty.id %>/deletes')">
                              <i class="fa fa-trash-o"></i>
                            </a> <% end %>
                          </td>
                        </tr>
                        <% i += 1 %>
                            <% end %>
                            <% end %>
                      </tbody>
                    </table>
										
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
                </div>
                <div class="tab-pane" id="tab2">
										<div class="row">
										 <% 
                       pagestart = params[:page].present? ? params[:page].to_i : 1
                         i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1
                      if @faculty_list && @faculty_list.length>0 
                             @faculty_list.each do |faculty| %> 
											<div class="col-md-4">
												<div class="card card-box">
													<div class="card-body no-padding ">
														<div class="doctor-profile">
                            	<%
						image_url = "https://user.gadjian.com/static/images/personnel_boy.png"
						pullimgpath = "https://ihm-inqerp.b-cdn.net"
						
							compcode = faculty.fclty_compcode
							img_path = faculty.fclty_img
						image_url = "#{pullimgpath}/#{compcode}/faculty/#{img_path}"
						
					   %>
                            <% if image_url.present? %>
															<img src="<%=image_url%>" class="doctor-pic img-thumbnail"
																alt="">
														<% else %>
                            <img src="<%= root_url %>images/no-image.jpg" class="doctor-pic img-responsive img-thumbnail" alt="">
                            <% end %>
															<div class="profile-usertitle">
																<div class="doctor-name"><%= faculty.fclty_name %> </div>
																
                                <%if faculty.fclty_gender == ''%>
                          <div class="name-center"></div>
                          <%elsif faculty.fclty_gender == 'M'%>
                          <div class="name-center">Male</div>
                          <%elsif faculty.fclty_gender == 'F'%>
                          <div class="name-center">Female</div>
                          <%elsif faculty.fclty_gender == 'Oth'%>
                          <div class="name-center">Other</div>
                          <%end%>
                                 
															</div>
															<p><%= faculty.fclty_addr1%> <br /> <%= faculty.fclty_city%></p>
															<div>
																<p><i class="fa fa-phone"></i><a
																		href="tel:(123)456-7890"> </a><%= faculty.fclty_contact%></p>
															</div>
															<div class="profile-userbuttons">
																<a href="<%=root_url%>faculty_list/add_faculty/<%= faculty.id%>"
																	class="btn btn-circle deepPink-bgcolor btn-sm">Edit</a>
								
															</div>
														</div>
													</div>
												</div>
											</div>
																				  <% i += 1 %>
                            <% end %>
                            <% end %>
											
										</div>
								
									</div>
								</div>

        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

