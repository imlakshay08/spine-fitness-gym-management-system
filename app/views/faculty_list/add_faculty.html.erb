					<input name="fclty_mother" id="fclty_mother"  type="text"  placeholder="Enter Mother's Name"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_mother%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_mother'] %><% end %>"/> 
				</label>
					</div>	
					</div>
					
					<div class="form-group row">
				
					<label class="col-md-3">State & Pincode
