					<label class="col-md-3">Designation
					</label>
					<div class="col-md-3">
					<input name="fclty_desig" id="fclty_desig"  type="text"  placeholder="Enter Designation"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_desig%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_desig'] %><% end %>"/> 
					</div>
