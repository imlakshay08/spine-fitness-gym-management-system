<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Members/Staff</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>faculty_list" class="float-right">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>
			<%= form_tag({action: 'create'}, multipart: :true, id: :myforms, class: "form-horizontal") do  %>
						<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>
            <input type="hidden" name="mid" id="mid" value="<% if @faculty %><%=@faculty.id%><% end %>"/>
			<input type="hidden" name="cur_fclty_code" id="cur_fclty_code" value="<% if @faculty %><%=@faculty.fclty_code%><% end %>"/>
			<input type="hidden" name="facultyimgeId" id="facultyimgeId" value="<% if @faculty %><%=@faculty.fclty_img%><% end %>"/>
			<input type="hidden" name="new_fac_img" id="new_fac_img" value=""/>
		<input type="hidden" name="myattachpropfile" id="myattachpropfile" value=""/>
		<input type="hidden" name="manualupdatecode" id="manualupdatecode" value=""/>
	<input type="hidden" name="cursignature" id="cursignature" value="<% if @faculty %><%=@faculty.fclty_signature%><% end %>"/>
					<div class="form-body">
						<%
						image_url = "https://user.gadjian.com/static/images/personnel_boy.png"
						pullimgpath = "https://ihm-inqerp.b-cdn.net"
						if @faculty
							compcode = @faculty.fclty_compcode
							img_path = @faculty.fclty_img
						image_url = "#{pullimgpath}/#{compcode}/faculty/#{img_path}"
						end
					   %>
					   	<div class="form-group row">
					   <div class="col-md-2 mmb100">
						<div class="profile-img-wrap edit-img">
						<a href="<%= image_url %>" class="example-image-link" data-lightbox="example-1">
							<img src="<%= image_url %>" class="img-responsive img-thumbnail" name="item-img-output" id="item-img-output" />
						</a>
						<div class="fileupload" style="position: absolute; bottom: 0px; left: 2px; background: #fff; color: #000; padding: 0px 20px; border-radius: 0px;">
							<label class="custom-file-upload" style="margin: 0px;">
							<input type="file" accept=".jpg,.png,.jpeg" class="upload item-img file center-block" name="fclty_img" id="fclty_img" style="display: none;" />
							<p style="margin: 0 0 0px; font-size: 13px;" onclick="document.getElementById('fclty_img').click();">Upload</p>
							</label>
						</div>
						</div>
					</div>
					<div class="col-md-10">
					<div class="form-group row">
					<label class="col-md-3">Code
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
										<input name="fclty_code" id="fclty_code"  type="text"  placeholder="Enter Code"
										autocomplete="off" maxlength="10" class="form-control" required value="<% if @faculty%><%=@faculty.fclty_code%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_code'] %><% end %>"/> 
										
					
					</div>
					<label class="col-md-3 age_calcualted">Date of Birth
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="fclty_dob" id="fclty_dob" type="text" placeholder="Select Date" autocomplete="off" maxlength="20" class="form-control" required value="<% if @faculty%><%=formatted_date(@faculty.fclty_dob)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_dob'] %><% end %>"/>
					</div>
						
					</div>

					</div>

					<div class="form-group row">
					<label class="col-md-3">Name
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="fclty_name" id="fclty_name"  type="text"  placeholder="Enter Name"
					autocomplete="off" maxlength="50" class="form-control" required value="<% if @faculty%><%=@faculty.fclty_name%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_name'] %><% end %>"/> 
					</div>
					<label class="col-md-3">Gender
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
						<select class="form-select select-height" required name="fclty_gender" id="fclty_gender">
							<option value="">Select...</option>
							<option value="M" <% if @faculty && @faculty.fclty_gender.to_s == 'M'%>selected<% end %>>Male</option>
							<option value="F"  <% if @faculty && @faculty.fclty_gender.to_s == 'F'%>selected<% end %>>Female</option>
							<option value="Oth"  <% if @faculty && @faculty.fclty_gender.to_s == 'Oth'%>selected<% end %>>Other</option>
						
						</select>
					</div>

					</div>

					<div class="form-group row">
					<label class="col-md-3">AEBAS ID
					<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="fclty_aebas_id" id="fclty_aebas_id"  type="text"  placeholder="Enter AEBAS ID"
					autocomplete="off" maxlength="6" class="form-control" required  onkeypress="return isNumberMyKeys(event);" value="<% if @faculty%><%=@faculty.fclty_aebas_id%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_aebas_id'] %><% end %>"/> 
					</div>
					<label class="col-md-3">Employee Code
					<span class="required"> * </span>
					</label>
						<div class="col-md-3">
					<input name="fclty_employee_code" id="fclty_employee_code"  type="text"  placeholder="Enter Employee Code"
					autocomplete="off" maxlength="10" class="form-control" required value="<% if @faculty%><%=@faculty.fclty_employee_code%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_employee_code'] %><% end %>"/> 
					</div>
					</div>

						<div class="form-group row">
						<label class="col-md-3">Joining Date
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="fclty_join_date" id="fclty_join_date" type="text" placeholder="Select Join Date" autocomplete="off" maxlength="20" class="form-control" value="<% if @faculty%><%=formatted_date(@faculty.fclty_join_date)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_join_date'] %><% end %>"/>
					</div></div>
					<label class="col-md-3">Leaving Date
					</label>
					<div class="col-md-3">
					<div class="input-group">
					<span class="input-group-addon iconinput-pd"><i class="fa fa-calendar"></i></span>
					<input name="fclty_leave_date" id="fclty_leave_date" type="text" placeholder="Select Leave Date" autocomplete="off" maxlength="20" class="form-control" value="<% if @faculty%><%=formatted_date(@faculty.fclty_leave_date)%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_leave_date'] %><% end %>"/>
					</div>
					</div>
					
					</div>



					</div>
					</div>
									
									

				
					<div class="mdl-tabs mdl-js-tabs">
