					<div class="col-md-3">
						<select class="form-select select-height"  name="fclty_mrtl_stats" id="fclty_mrtl_stats">
							<option value="">Select...</option>
							
							<option value="M" <% if @faculty && @faculty.fclty_mrtl_stats.to_s == 'M'%>selected<% end %>>Married</option>

							<option value="UM" <% if @faculty && @faculty.fclty_mrtl_stats.to_s == 'UM'%>selected<% end %>>UnMarried</option>

							<option value="W" <% if @faculty && @faculty.fclty_mrtl_stats.to_s == 'W'%>selected<% end %>>Widow</option>

							<option value="S" <% if @faculty && @faculty.fclty_mrtl_stats.to_s == 'S'%>selected<% end %>>Single Parent</option>
						</select>
					</div>
					
				
				</div>
					<div class="form-group row">
