					<div class="col-md-3">
					<input name="fclty_city" id="fclty_city"  type="text"  placeholder="Enter State & Pincode"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_city%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_city'] %><% end %>"/> 
					</div>
					<label class="col-md-3">Spouse's Name
					
					</label>
					<div class="col-md-3">
						<input name="fclty_spouse" id="fclty_spouse"  type="text"  placeholder="Enter Spouse's Name"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_spouse%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_spouse'] %><% end %>"/> 
					</div>
					</div>

