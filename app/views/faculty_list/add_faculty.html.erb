					</label>
					<div class="col-md-3">
					<input name="fclty_cghs_id" id="fclty_cghs_id"  type="text"  placeholder="Enter CGHS ID"
					autocomplete="off" maxlength="10" class="form-control" onkeypress="return isNumberMyKeys(event);" value="<% if @faculty%><%=@faculty.fclty_cghs_id%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_cghs_id'] %><% end %>"/> 
					</div>
