					<div class="col-md-3">
					<input name="fclty_father" id="fclty_father"  type="text"  placeholder="Enter Father's Name"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_father%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_father'] %><% end %>"/> 
				</label>
					</div>
					</div>

						<div class="form-group row">
				
					<label class="col-md-3">Address 2
					
					</label>
					<div class="col-md-3">
					<input name="fclty_addr2" id="fclty_addr2"  type="text"  placeholder="Enter Address 2"
					autocomplete="off" maxlength="150" class="form-control" value="<% if @faculty%><%=@faculty.fclty_addr2%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_addr2'] %><% end %>"/> 
					</div>
