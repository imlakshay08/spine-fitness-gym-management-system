					autocomplete="off" maxlength="40" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_paylevel%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_paylevel'] %><% end %>"/> 
