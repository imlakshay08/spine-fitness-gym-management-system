					</label>
					<div class="col-md-3">
					<input name="fclty_qlf" id="fclty_qlf"  type="text"  placeholder="Enter Qualification"
					autocomplete="off" maxlength="50" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_qlf%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_qlf'] %><% end %>"/> 
					</div>

				<label class="col-md-3">Blood Group
					</label>
					<div class="col-md-3">
						<select class="form-select select-height"  name="fclty_blood_group" id="fclty_blood_group">
							<option value="">Select...</option>
						 <option value="A+" <% if @faculty && @faculty.fclty_blood_group.to_s == 'A+'%>selected<% end %>>A+</option>
						<option value="A-"  <% if @faculty && @faculty.fclty_blood_group.to_s == 'A-'%>selected<% end %>>A-</option>
						<option value="B+"  <% if @faculty && @faculty.fclty_blood_group.to_s == 'B+'%>selected<% end %>>B+</option>
						<option value="B-"  <% if @faculty && @faculty.fclty_blood_group.to_s == 'B-'%>selected<% end %>>B-</option>
						<option value="AB+" <% if @faculty && @faculty.fclty_blood_group.to_s == 'AB+'%>selected<% end %>>AB+</option>
						<option value="AB-" <% if @faculty && @faculty.fclty_blood_group.to_s == 'AB-'%>selected<% end %>>AB-</option>
						<option value="O+"  <% if @faculty && @faculty.fclty_blood_group.to_s == 'O+'%>selected<% end %>>O+</option>
						<option value="O-"  <% if @faculty && @faculty.fclty_blood_group.to_s == 'O-'%>selected<% end %>>O-</option>
						</select>
					</div>

				</div>

					<div class="form-group row">
