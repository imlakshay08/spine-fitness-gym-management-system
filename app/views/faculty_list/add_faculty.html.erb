					<span class="input-group-addon iconinput-pd"><i class="fa fa-phone"></i></span>
					<input name="fclty_emergency_no" id="fclty_emergency_no" onkeypress="return isNumberMyKeys(event);"  type="text"  placeholder="Enter Emergency Contact No."
					autocomplete="off" maxlength="10" class="form-control"  value="<% if @faculty%><%=@faculty.fclty_emergency_no%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_emergency_no'] %><% end %>"/> 
					</div>
					</div>
					</div>

						<div class="form-group row">
						<label class="col-md-3">Valid Upto
					</label>
					<div class="col-md-3">
					
					<input name="fclty_valid_upto" id="fclty_valid_upto" type="text" placeholder="Enter Valid Upto" autocomplete="off" maxlength="20" class="form-control" value="<% if @faculty%><%=@faculty.fclty_valid_upto%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['fclty_valid_upto'] %><% end %>"/>
					</div>

					<%
						pullimgpath = "https://ihm-inqerp.b-cdn.net"
						if @faculty
							compcode = @faculty.fclty_compcode
							signimg_path = @faculty.fclty_signature
						sign_image_url = "#{pullimgpath}/#{compcode}/facultysign/#{signimg_path}"
						end
					   %>

					<label class="col-md-3">Signature
					<% if @faculty%><% if @faculty.fclty_signature.present?%><a href="<%=sign_image_url%>" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="View Signature"><i class="fa fa-eye"></i></a><%end %><%end %>
					</label>
					<div class="col-md-3">
					 <input type="file" accept=".jpg,.png,.jpeg" name="fclty_signature" id="fclty_signature"/>
