<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Membership Plans</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                                        <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-1">Search</label>
                    <div class="col-sm-12 col-md-4">  <input type="text" class="form-control" name="membership_plan" id="membership_plan"  autocomplete="off" placeholder=""  value="<% if @membership_plan_search %><%=@membership_plan_search%><% end %>"/></div>
                    
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_membership_plan();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-2">  
                    <a href="<%=root_url%>membership_plan/referesh_membership_plan" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>membership_plan/add_membership_plan"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Membership Plan</button> </a>
                      </div> 
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>

                      </div>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="<%=root_url%>membership_plan/1_prt_subject_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10 " style="float:right;">PDF</button> </a>
                      </div>
                      </div>
											
												<table 
                        class="table table-striped table-bordered table-hover "
                        id="example4">
													<thead>
														<tr>
															<th>S.No</th>
                              <th>Plan Name</th>
                              <th>Plan Duration(No. of Days)</th>
                            	<th>Plan Amount</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                                         <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @membership_plan && @membership_plan.length>0 %>
                            <% @membership_plan.each do |plan| %>    

														<tr  class="odd gradeX">
															<td><%= i %></td>
                            	<td><%= plan.plan_name %></td>
                            	<td><%= plan.plan_duration_days %> Days</td>
                               <td> Rs. <%= plan.plan_amount %> </td>
                              <td>
                              <a href="<%= root_url %>membership_plan/add_membership_plan/<%= plan.id %>"
                                class="tblEditBtn">
                                <i class="fa fa-pencil"></i>
                              </a>
                              <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>membership_plan/<%= plan.id %>/deletes')">
                                <i class="fa fa-trash-o"></i>
                              </a>
                            </td>
														</tr>
                          <% i += 1 %>
                            <% end %>
                            <% end %>
													</tbody>
												</table>
											
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

