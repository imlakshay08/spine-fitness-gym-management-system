    if controller.controller_name  =='student_list' || controller.controller_name  =='print_student_id_card' || controller.controller_name  =='student_transaction_list' || controller.controller_name  =='student_data_import'

        masterpanel                 = "block"
        masterclass                 = "subdrop" 			       
