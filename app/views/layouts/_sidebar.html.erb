        commonflagsstyl       		  = "block"
        masteropen          	      = "open"
    elsif controller.controller_name == 'component_list' || controller.controller_name  =='fee_list' || controller.controller_name  =='fee_import' || controller.controller_name  =='fee_dashboard'
      feemasterpanel                 = "block"
      feemasterclass                 = "subdrop" 			       
      commonflags           	       = "subdrop"
      commonflagsstyl       		     = "block"
      feemasteropen          	       = "open"
    elsif controller.controller_name  =='time_table' && controller.action_name == 'faculty_view'
      facultypanel                   = "block"
      facultyclass                   = "subdrop" 			       
      commonflags           	       = "subdrop"
      commonflagsstyl       		     = "block"
      facultyopen          	         = "open"
    elsif controller.controller_name == 'time_table' || controller.controller_name  =='time_table_date_parameter'
