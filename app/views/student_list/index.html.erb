<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Student List-Profile</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
          <div class="row">
          <div class="col-md-12">
            <div class="tabbable-line">
              <ul class="nav customtab nav-tabs" role="tablist">
                <li class="nav-item"><a href="#tab1" class="nav-link active"
                    data-bs-toggle="tab">List
                    View</a></li>
                <li class="nav-item"><a href="#tab2" class="nav-link" data-bs-toggle="tab">Grid
                    View</a></li>
              </ul>
              <div class="tab-content">
									<div class="tab-pane active fontawesome-demo" id="tab1">
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>

                    <%= form_tag({:action=>'index'} ,method: :post ,:multipart=>true,:id=>'myForms') do  %>
					            <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-2">Registration No.</label>
                    <div class="col-sm-12 col-md-2">  <input type="text" class="form-control" name="student_list" id="student_list"  autocomplete="off" placeholder="Enter Registration number"  value="<% if @student_list_search %><%=@student_list_search%><% end %>"/></div>
                     <label class="col-sm-12 col-md-1">Course Code</label>
                    <div class="col-sm-12 col-md-2">  
                    	<select class="form-select select-height"  name="course_search" id="course_search">
							<option value="">Select...</option>
              <%
                        if @CourseList && @CourseList.length>0
                            @CourseList.each do |course|
                    %>
                    <option value="<%=course.id%>" <% if @course_search && @course_search.to_i == course.id.to_i %>selected="selected"<% end %>><%=course.crse_code%></option>
                    <%
                    end
                    end
                    %>
						</select>
                    </div>
                     <label class="col-sm-12 col-md-1">Year</label>
                    <div class="col-sm-12 col-md-2">
                      <select class="form-select select-height" name="year_search" id="year_search">
                        <option value="">Select Year...</option>
                        <option value="1"<%= 'selected' if params[:year_search] == '1' %>>1st Year</option>
                        <option value="2"<%= 'selected' if params[:year_search] == '2' %>>2nd Year</option>
                        <option value="3"<%= 'selected' if params[:year_search] == '3' %>>3rd Year</option>
                      </select>
                    </div> 

                    <div class="col-sm-12 col-md-1">  
                    <button data-bs-toggle="button" class="btn btn-circle btn-default" onclick="filter_student_list();"><i class="fa fa-search"></i>
											</button>
                    </div> 
                    <div class="col-sm-12 col-md-1">  
                    <a href="<%=root_url%>student_list/referesh_student_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <% if @myAddAld %>
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>student_list/student_admission"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Student Admission</button> </a>
                      </div>
                      <% end %>
                      <% if @student_list && @student_list.length>0 %>
                       <% if @myPrintAld %>
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>student_list/1_prt_student_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">PDF</button> </a>
                      </div>
                      <% end %>
                      <% end %>
                      </div>
										
                      <table
                      class="table table-striped table-bordered table-hover "
                      id="example4" >
                      <thead>
                        <tr>
                          <th>S.No</th>
                          <th> Registration No. </th>
                          <th> Registration Date </th>
                          <th> NCHM No. </th>
                          <th> Course Code  </th>
                          <th> Optional Subject </th>
                          <th> Name </th>
                          <th>Gender</th>
                          <th>Date of Birth</th>
                          <th> Action </th>
                        </tr>
                      </thead>
                      <tbody>
					  <%  
					  pagestart = params[:page].present? ? params[:page].to_i : 1
                         i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1
					  
					  if @student_list && @student_list.length>0 
                        @student_list.each do |student_list|

                        nhmcno=""
                        nhmcobj=get_general_information(student_list.stdnt_compcode,student_list.stdnt_reg_no)
                        if nhmcobj
                          nhmcno=nhmcobj.stdnt_gn_nhmc
                        end

                        coursecode=""
                        otpno=""
                        courseobj=get_personal_information(student_list.stdnt_compcode,student_list.stdnt_reg_no)
                        if courseobj
                            otpno= courseobj.stdnt_otp
                            rolobj      = get_course_student(student_list.stdnt_compcode,courseobj.stdnt_dtl_crse)
                            if rolobj
                            coursecode = rolobj.crse_code
                            end
                        end

                        optionalsubj=""
                        optionsubname=""
                        optionalsubjobj=get_general_information(student_list.stdnt_compcode,student_list.stdnt_reg_no)
                        if optionalsubjobj
                            optionalobj = get_optional_subject(student_list.stdnt_compcode,optionalsubjobj.stdnt_gn_opt_sub)
                            if optionalobj
                              optionalsubj = optionalobj.sub_code
                              optionsubname= optionalobj.sub_name
                            end
                        end

						%> 
                        <tr class="odd gradeX">
                        <td class="left"> <%= i %> </td>
                          <td class="left">
                        <%= student_list.stdnt_reg_no %>
                          </td>
                          <td class="left"><%= formatted_date(student_list.stdnt_reg_date) %></td>
                          <td><%=nhmcno%></td>
                         
                          <td class="left"><%=coursecode%></td>
                          <% if optionsubname.present?%>
                          <td class="left"><%=optionsubname%></td>
                          <%else%>
                          <td class="left">N/A</td>
                          <%end%>
                          <td class="left"><%= student_list.stdnt_fname %> <%= student_list.stdnt_lname %> <% if otpno.present?%> (<%=otpno%>)<%end%>
			</td>
                          <%if student_list.stdnt_gender == ''%>
                          <td class="left"></td>
                          <%elsif student_list.stdnt_gender == 'M'%>
                          <td class="left">Male</td>
                          <%elsif student_list.stdnt_gender == 'F'%>
                          <td class="left">Female</td>
                          <%elsif student_list.stdnt_gender == 'OTH'%>
                          <td class="left">Other</td>
                          <%elsif student_list.stdnt_gender.present?%>
                          <td class="left"></td>
                          <%end%>
						  <td class="left"><%= formatted_date(student_list.stdnt_dob) %></td>
                          <td>
			<% if @onlyViewSelected %>
                          <a href="<%= root_url %>student_list/student_admission/<%= student_list.id %>" class="tblEditBtn">
                              <i class="fa fa-eye"></i>
                            </a>
                            <%else%>
                             <a href="<%= root_url %>student_list/student_admission/<%= student_list.id %>" class="tblEditBtn">
                              <i class="fa fa-eye hidden"></i>
                            </a>
                            <% end %>
                          <% if @myEditAld %>
                            <a href="<%= root_url %>student_list/student_admission/<%= student_list.id %>" class="tblEditBtn">
                              <i class="fa fa-pencil"></i>
                            </a>
                            <% end %>
                            <% if @myDeletAld %>
                            <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>student_list/<%= student_list.id %>/deletes')">
                              <i class="fa fa-trash-o"></i>
                            </a>
                            <% end %>
                          </td>
                        </tr>
                                             
                       <% i += 1 %>
                            <% end %>
                            <% end %>
                      </tbody>
                    </table>
										
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
                </div>
                <div class="tab-pane" id="tab2">
										<div class="row">
										 <% 
                       pagestart = params[:page].present? ? params[:page].to_i : 1
                         i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1
                      if @student_list && @student_list.length>0 
                             @student_list.each do |student_list| 
                              
                              contactno  = ""
                              addressfst = ""
                              stdntcity  = ""
                              persondtobj = get_personal_information(student_list.stdnt_compcode,student_list.stdnt_reg_no)
                              if persondtobj
                                 contactno = persondtobj.stdnt_dtl_cont
                                 addressfst = persondtobj.stdnt_dtl_add1
                                 stdntcity  = persondtobj.stdnt_dtl_city
                              end
                              %> 
                              <% pullimgpath = "https://ihm-inqerp.b-cdn.net" %>
											<div class="col-md-4">
												<div class="card card-box">
													<div class="card-body no-padding ">
														<div class="doctor-profile">
                            <% if student_list.stdnt_img.present? %>
                            <% compcode = student_list.stdnt_compcode %>
                            <% img_path = student_list.stdnt_img %>
                            <% student_image_url = "#{pullimgpath}/#{compcode}/student/#{img_path}" %>
                            <a href="<%= student_image_url %>" class="example-image-link" data-lightbox="example-1"><img src="<%= student_image_url %>" class="doctor-pic img-thumbnail" alt="<%= student_list.stdnt_fname %>"/></a>
                          <% else %>
                            <img src="<%= root_url %>images/no-image.jpg" class="doctor-pic img-thumbnail" alt="No Image"/>
                          <% end %>
															<div class="profile-usertitle">
																<div class="doctor-name"><%= student_list.stdnt_fname %> <%= student_list.stdnt_lname %> </div>
																<%if student_list.stdnt_gender == ''%>
                          <div class="name-center"></div>
                          <%elsif student_list.stdnt_gender == 'M'%>
                          <div class="name-center">Male</div>
                          <%elsif student_list.stdnt_gender == 'F'%>
                          <div class="name-center">Female</div>
                          <%elsif student_list.stdnt_gender == 'Oth'%>
                          <div class="name-center">Other</div>
                          <%elsif student_list.stdnt_gender.present?%>
                          <td class="left"></td>
                          <%end%>
															</div>
														 <p><%= addressfst%> <br /> <%= stdntcity%></p>
															<div>
																<p><i class="fa fa-phone me-1"></i><a href="tel:<%=contactno%>"><%=contactno%> </a></p>
															</div>
															<div class="profile-userbuttons">
																<a href="<%=root_url%>student_list/student_admission/<%= student_list.id %>"
																	class="btn btn-circle deepPink-bgcolor btn-sm">Edit</a>
															</div>
														</div>
													</div>
												</div>
											</div>
										<% i += 1 %>
                            <% end %>
                            <% end %>
											</div>
										</div>
								
									</div>
								</div>

        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

