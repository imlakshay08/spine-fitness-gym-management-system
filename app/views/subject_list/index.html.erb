<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Subject List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                                        <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-1">Search</label>
                    <div class="col-sm-12 col-md-4">  <input type="text" class="form-control" name="subject_list" id="subject_list"  autocomplete="off" placeholder="Enter Subject Code & Name"  value="<% if @subject_list_search %><%=@subject_list_search%><% end %>"/></div>
                   <label class="col-sm-12 col-md-1">Course </label>
                    <div class="col-sm-12 col-md-3">  
                    	<select class="form-select select-height"  name="course_search" id="course_search">
                  <option value="">Select...</option>
                   <%
                        if @CourseList && @CourseList.length>0
                            @CourseList.each do |course|
                    %>
                    <option value="<%=course.id%>" <% if @course_search && @course_search.to_i == course.id.to_i %>selected="selected"<% end %>><%=course.crse_code%></option>
                    <%
                    end
                    end
                    %>
                </select>

                    </div>
                    
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_subject_list();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-2">  
                    <a href="<%=root_url%>subject_list/referesh_subject_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row"><% if @myAddAld || @myEditAld %>
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>subject_list/add_subject"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Subject</button> </a>
                      </div> <%end%>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>

                      </div>
                      <% if @subject_list && @subject_list.length>0 %>
                      <% if @myPrintAld %>
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>subject_list/1_prt_subject_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10 " style="float:right;">PDF</button> </a>
                      </div><% end %>
                      <% end %>
                      </div>
											
												<table 
                        class="table table-striped table-bordered table-hover "
                        id="example4">
													<thead>
														<tr>
															<th>S.No</th>
                              <th>Course</th>
                              <th>Subject Code</th>
                            	<th>Name</th>
                              <th>Type</th>
                             
                              <th>Active</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                                         <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @subject_list && @subject_list.length>0 %>
                            <% @subject_list.each do |subject| %>    
                              <%       
														courseobj = get_course_detail(subject.sub_crse)
                            if courseobj
                               coursename = courseobj.crse_descp
                               coursecode = courseobj.crse_code
                            end
                            %>
														<tr  class="odd gradeX">
															<td><%= i %></td>
                               <td> <%=coursecode%> 
                             <%  if coursename.present? %>  
                               - <%= coursename %> 
                               <% end %>
                               </td>
                            	<td><%= subject.sub_code %></td>
                              <td><%= subject.sub_name %></td>
                            	<td><%= subject.sub_type %></td>
                             
                              <td><%= subject.sub_activ == 'Y' ? 'Y' : 'N' %></td>
                              <td><% if @myEditAld %>
                              <a href="<%= root_url %>subject_list/add_subject/<%= subject.id %>"
                                class="tblEditBtn">
                                <i class="fa fa-pencil"></i><% end %>
                              </a><% if @myDeletAld %>
                              <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>subject_list/<%= subject.id %>/deletes')">
                                <i class="fa fa-trash-o"></i>
                              </a> <% end %>
                            </td>
														</tr>
                          <% i += 1 %>
                            <% end %>
                            <% end %>
													</tbody>
												</table>
											
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

