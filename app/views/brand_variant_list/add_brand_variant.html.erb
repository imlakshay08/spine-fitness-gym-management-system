<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Brand</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>brand_variant_list?page=<%=params[:page] %>" style="float:right;">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
			<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>
					<%= form_tag({:action=>'create'} ,:multipart=>true,:id=>'myForms' ) do  %>
            <input type="hidden" name="mid" id="mid" value="<% if @Variant %><%=@Variant.Id%><% end %>"/>

					<div class="form-body">
						
					<div class="form-group row">
					<label class="col-md-3">Brand Name
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="Brand_Name" required id="Brand_Name" type="text"  placeholder="Enter Brand Name"
					autocomplete="off" maxlength="90" class="form-control" value="<% if @Variant%><%=@Variant.Brand_Name%><% end %>" required/> 
					</div>

					<label class="col-md-3">Active
				<span class="required"> * </span>
			</label>
				<div class="col-md-3">
				<label class="mdl-switch mdl-js-switch mdl-js-ripple-effect"
				for="Isactive">
				<input type="hidden" name="Isactive" value="N">
       			 <input type="checkbox" id="Isactive" name="Isactive" class="mdl-switch__input" value="Y" <%= @Variant&.Isactive == 'Y' ? 'checked' : '' %>>
			</label>
			</div>
					<label  class="col-md-3 hidden">Variant Name
				</label>
				<div class="col-md-3 hidden">
				<input  name="Variant_Name" id="Variant_Name" type="text" placeholder="Enter Variant Name"
				autocomplete="off" maxlength="90" class="form-control" value="<% if @Variant%><%=@Variant.Variant_Name%><% end %>"/> 
				</div>

				</div>


						<div class="form-group row hidden">
				
						<label class=" col-md-3 col-6">Segment Type
						<span class="required"> * </span>
						</label>
						<div class="col-md-3">
						<select name="Segment_Type" id="Segment_Type" class="form-control"> 
    					<option>--Select--</option>
    					<option value="RSFT" <%= 'selected="selected"' if @Variant&.Segment_Type.to_s == 'RSFT' %>>RSFT</option>
   						 <option value="KSFT" <%= 'selected="selected"' if @Variant&.Segment_Type.to_s == 'KSFT' %>>KSFT</option>
						</select>

						</div>
						<label class="col-md-3">Segment Full form
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<input name="Segment_Full_Form" id="Segment_Full_Form" type="text"  placeholder="Segment Full form"
					autocomplete="off" maxlength="99" class="form-control" value="<% if @Variant%><%=@Variant.Segment_Full_Form%><% end %>"/> 
					</div>
					
					</div>
					
					<div class="form-group row">
					

					<label class="col-md-3 hidden">Pack Size
				</label>
				<div class="col-md-3 hidden">
				<input name="Pack_Size" id="Pack_Size" type="text" placeholder="Enter Pack Size"
				autocomplete="off" maxlength="3" class="form-control" value="<% if @Variant%><%=@Variant.Pack_Size%><% end %>"/> 
				</div>
				
				</div>
					
							<div class="form-group form-button text-center  m-b-20" style="margin-top: 50px;">
							<button type="submit"
							class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 m-r-20 btn-circle btn-primary">SUBMIT</button>
								<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
							<a href="<%=root_url%>brand_variant_list?page=<%=params[:page] %>">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>
				</form>
				<% end %>
			</div>
		</div>
	</div>
</div>

			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>