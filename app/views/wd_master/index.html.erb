<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">WD Master</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-2">WD Name & Code</label>
                    <div class="col-sm-12 col-md-3">  <input type="text" class="form-control" name="WD" id="WD" autocomplete="off" placeholder="Enter WD Name & Code"  value="<% if @wd_master_search %><%=@wd_master_search%><% end %>"/></div>
                  
                    <div class="col-sm-12 col-md-1">  
                    <button data-bs-toggle="button" class="btn btn-circle btn-default" onclick="filter_wd_list();"><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-6">  
                    <a href="<%=root_url%>wd_master/referesh_wd_master" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>wd_master/add_wd"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add WD</button> </a>
                      </div>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>
                      </div>
                      </div>
											<div class="table-scrollable">
												<table class="table">
													<thead>
														<tr>
															<th>S.No</th>
															<th>Branch</th>
															<th>City</th>
                            	<th>WD Name</th>
                              <th>WD Code</th>
                              <th>Active</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                          <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @wd_master.any? %>
                            <% @wd_master.each do |wd| %>
														<tr>
															<td><%= i %></td>
                              <td><%= MstBranch.find_by(Id: wd.Ref_Branch_id)&.Branch_Code %></td>
                              <td><%= MstCity.find_by(Id: wd.Ref_City_id)&.City %></td>
                              <td><%= wd.WDName %></td>
                              <td><%= wd.WDCode %></td>
                              <td><%= wd.Isactive == 'Y' ? 'Y' : 'N' %></td>
                              <td>
                              <a href="<%= root_url %>wd_master/add_wd/<%= wd.Id %>?page=<%=params[:page] %>" class="tblEditBtn">
                                    <i class="fa fa-pencil"></i>
                                  </a>
                              <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>wd_master/<%= wd.Id %>/deletes')">
                                <i class="fa fa-trash-o"></i>
                              </a>
                            </td>
														</tr>
                              <% i += 1 %>
                            <% end %>
                          <% else %>
                            <tr>
                              <td colspan="6">No data available</td>
                            </tr>
                          <% end %>
													</tbody>
												</table>
											</div>
                     
                    <div class="col-md-12 text-center"><%= will_paginate @wd_master %></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

