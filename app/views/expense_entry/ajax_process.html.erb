									  Action
									</th>
								</tr>
								</thead>
								<tbody>
							
								<tr>
									<td id="center">
									1
									</td>
                                                                        <td>
									001
									</td>
                                                                         <td>
                                                                         Mr XYZ
									</td>
									<td>Travelling</td>
									<td>
									Local
									</td>
									<td>
									Rs 1000
									</td>
									
									<td >
									<a href="<%=root_url%>insurerinfo"><i class="fa fa-pencil-square-o hrmsfonts_size" aria-hidden="true"></i></a>
                                                                         <a href="javascript:void(0);" rel="<%=root_url%>insurerinfo" onclick="confirmDeletion(this);"><i class="fa fa-trash-o hrmsfonts_size" aria-hidden="true"></i></a>-
									</td>
								</tr>
								
								</tbody>
								</table>
							</div>

					
						<div class="row">
					
					<div class="col-md-2 col-xs-4">
					<input type="image" src="<%=root_url%>images/save.png"/>
					</div>
					<div class="col-md-3 col-xs-4">
					<a href="<%=root_url%>dashboard">
                                         &nbsp;<img src="<%=root_url%>images/Quit.png"/>
                                        </a>
					</div>
                                         
					</div>
				
					
					<!-- END SAMPLE TABLE PORTLET-->
				</div>
					
                                <% end %>
			
                                                    <!-- END PAGE CONTENT-->
                                            </div>
                                        </div>
                                    <!-- END CONTENT -->
                                  </div>
                              </div>
                            </div>
                      </div>
                </div>
            </div>
       
<!-- END CONTAINER -->
<%=render "layouts/popupforms"%>