<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Pack Size</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>pack_size?page=<%=params[:page] %>" style="float:right;">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>
					<%= form_tag({:action=>'create'} ,:multipart=>true,:id=>'myForms' ) do  %>
            <input type="hidden" name="mid" id="mid" value="<% if @pack %><%=@pack.id%><% end %>"/>
					<div class="form-body">
						
					<div class="form-group row">

					<label class="col-md-3">Pack Size
                    <span class="required"> * </span>
				</label>
				<div class="col-md-3">
				<input name="ps_packsize" id="ps_packsize" onkeypress="return isNumberMyKeys(event);" type="text" placeholder="Enter Pack Size"
				autocomplete="off" maxlength="3" class="form-control" value="<% if @pack%><%=@pack.ps_packsize%><% end %>"/> 
				</div>

                    <label class="col-md-3">Active
						<span class="required"> * </span>
					</label>
					<div class="col-md-3">
					<label class="mdl-switch mdl-js-switch mdl-js-ripple-effect"
													for="ps_status">
													<input type="hidden" name="ps_status" value="N">
       			 <input type="checkbox" id="ps_status" name="ps_status" class="mdl-switch__input" value="Y" <%= @pack&.ps_status == 'Y' ? 'checked' : '' %>>

												</label>
				
					</div>
				</div>
		
							<div class="form-group form-button text-center  m-b-20" style="margin-top: 50px;">
							<button type="submit"
							class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 m-r-20 btn-circle btn-primary">SUBMIT</button>
								<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
							<a href="<%=root_url%>pack_size?page=<%=params[:page] %>">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>
				</form>
				<% end %>
			</div>
		</div>
	</div>
</div>
					
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>
