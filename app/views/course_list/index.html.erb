<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Course List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-1">Search</label>
                    <div class="col-sm-12 col-md-4">  <input type="text" class="form-control" name="course_list" id="course_list"  autocomplete="off" placeholder="Enter Course Code & Description"  value="<% if @course_list_search %><%=@course_list_search%><% end %>"/></div>
                  
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_course_list();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                     <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-6">  
                    <a href="<%=root_url%>course_list/referesh_course_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>course_list/add_course"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Course</button> </a>
                      </div>
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>
                      </div>
                                          <% if @course_list && @course_list.length>0 %>
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>course_list/1_prt_course_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">PDF</button> </a>
                      </div>
                      <% end %>
                      </div>
											
												<table 
                        class="table table-striped table-bordered table-hover "
                          id="example4">
													<thead>
														<tr  class="odd gradeX">
															<th>S.No</th>
                              <th>Course Code</th>
                            	<th>Description</th>
                              <th>Duration of Course</th>
                              <th>Total No. of Seats</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                                   <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @course_list && @course_list.length>0 %>
                            <% @course_list.each do |course| %>               
													
														<tr>
															<td><%= i %></td>
                            	<td><%= course.crse_code %></td>
                              <td><%= course.crse_descp %></td>
                            	<td><%= course.crse_duration %></td>
                              <td><%= course.crse_seats %></td>
                              <td>
                              <a href="<%= root_url %>course_list/add_course/<%= course.id %>"
                                class="tblEditBtn">
                                <i class="fa fa-pencil"></i>
                              </a>
                              <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>course_list/<%= course.id %>/deletes')">
                                <i class="fa fa-trash-o"></i>
                              </a>
                            </td>
														</tr>
                          <% i += 1 %>
                            <% end %>
                            <% end %>
													</tbody>
												</table>
										
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

