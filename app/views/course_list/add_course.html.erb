<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Course</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>course_list" class="float-right">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>
			<%= form_tag({action: 'create'}, multipart: :true, id: :myforms, class: "form-horizontal") do  %>
			<input type="hidden" name="cur_course_code" id="cur_course_code" value="<% if @course %><%=@course.crse_code%><% end %>"/>
            <input type="hidden" name="mid" id="mid" value="<% if @course %><%=@course.id%><% end %>"/>
						<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>

					<div class="form-body">
						
					<div class="form-group row">
					<label class="col-md-3">Course Code
						<span class="required"> * </span>
					</label>
					<div class="col-md-4">
					<% if @course %>
					<input name="crse_code" id="crse_code"  type="text"  placeholder="Enter Course Code"
					autocomplete="off" maxlength="10" readonly class="form-control" required value="<% if @course%><%=@course.crse_code%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['crse_code'] %><% end %>"/> 
					<%else %>
					<input name="crse_code" id="crse_code"  type="text"  placeholder="Enter Course Code"
					autocomplete="off" maxlength="10" class="form-control" required value="<% if @course%><%=@course.crse_code%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['crse_code'] %><% end %>"/> 
					<%end%>
					</div>
					</div>
					<div class="form-group row">
					<label class="col-md-3">Course Description 
					<span class="required"> * </span>
				</label>
				<div class="col-md-4">
				<input name="crse_descp" id="crse_descp"  type="text"  placeholder="Enter Course Description"
					autocomplete="off" maxlength="100" class="form-control" required value="<% if @course%><%=@course.crse_descp%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['crse_descp'] %><% end %>"/> 
				</div>

				</div>


						<div class="form-group row">
				
						<label class=" col-md-3 col-6">Duration of Course
						<span class="required"> * </span>
						</label>
						<div class="col-md-4">
						<select class="form-select select-height" required name="crse_duration" id="crse_duration">
							<option value="">Select...</option>
							<option value="6 Months" <% if @course && @course.crse_duration.to_s =='6 Months'%>selected="selected"<% end %>>6 Months</option>
							<option value="1 Year" <% if @course && @course.crse_duration.to_s =='1 Year'%>selected="selected"<% end %>>1 year</option>
							<option value="2 Year"<% if @course && @course.crse_duration.to_s =='2 Year'%>selected="selected"<% end %>>2 year</option>
							<option value="3 Year" <% if @course && @course.crse_duration.to_s =='3 Year'%>selected="selected"<% end %>>3 year</option>
						</select>
						</div>
					</div>

					
					<div class="form-group row">
				
					<label class=" col-md-3 col-6">Course Term
					<span class="required"> * </span>
					</label>
					<div class="col-md-4">
					<select class="form-select select-height" required name="crse_term" id="crse_term">
						<option value="">Select...</option>
						<option value="Semester" <% if @course && @course.crse_term.to_s =='Semester'%>selected="selected"<% end %>>Semester</option>
						<option value="Annual" <% if @course && @course.crse_term.to_s =='Annual'%>selected="selected"<% end %>>Annual</option>
						
					</select>
					</div>
				</div>

					<div class="form-group row">
					<label class=" col-md-3 col-6">Total No. of Seats
					<span class="required"> * </span>
					</label>
					<div class="col-md-4">
					<input name="crse_seats" id="crse_seats" onkeypress="return isNumberMyKeys(event);" type="text"  placeholder="Total No. of Seats"
					autocomplete="off" maxlength="10" class="form-control" required value="<% if @course%><%=@course.crse_seats%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['crse_seats'] %><% end %>"/> 
					</div>
					</div>

							<div class="form-group form-button text-center  m-b-20" style="margin-top: 50px;">
							<button type="submit"
							class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 m-r-20 btn-circle btn-primary">SUBMIT</button>
								<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
							<a href="<%=root_url%>course_list">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>
				</form>
				<% end %>
			</div>
		</div>
	</div>
</div>
					
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>