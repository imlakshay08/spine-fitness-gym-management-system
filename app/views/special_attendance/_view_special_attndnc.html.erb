                  <input type="checkbox" name="sp_att_prd8[]"  id="sp_att_prd8<%=i%>" value="Y" style="width: 20px;height: 25px;" <%= attndnce&.sp_att_prd8 == 'Y' ? 'checked' : '' %>>
