                  <input type="checkbox" name="sp_att_prd4[]" id="sp_att_prd4<%=i%>" value="Y"  style="width: 20px;height: 25px;" <%= attndnce&.sp_att_prd4 == 'Y' ? 'checked' : '' %>>
                  </td>
              <td class="text-center">
                  <input type="checkbox" name="sp_att_prd5[]"  id="sp_att_prd5<%=i%>" value="Y" style="width: 20px;height: 25px;" <%= attndnce&.sp_att_prd5 == 'Y' ? 'checked' : '' %>>
