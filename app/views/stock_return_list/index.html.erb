<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Stock Return List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    
                    <%= form_tag({:action=>'index'} ,:multipart=>true,:id=>'myForms' ) do  %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row">
                    <div class="col-sm-12 col-md-2 margin-top-10"> <input type="checkbox" name="filter_by_date" id="filter_by_date" value="Y" <% if @filter_by_date %>checked<% end %>/>&nbsp;Filter by date </div>
                    <div class="col-sm-12 col-md-2"> <input type="text" class="form-control " name="from_dated" id="from_dated" autocomplete="off"  placeholder="From Date"  value="<% if @from_dated %><%=formatted_date(@from_dated)%><% else %><%=formatted_date(Date.today)%><% end %>"/></div>
                    <div class="col-sm-12 col-md-2">  <input type="text" class="form-control" name="upto_dated" id="upto_dated" autocomplete="off" placeholder="To Date"  value="<% if @upto_dated %><%=formatted_date(@upto_dated)%><% else %><%=formatted_date(Date.today)%><% end %>"/></div>
                    <div class="col-sm-12 col-md-2">  
                    <select class="form-control" name="market_listed" id="market_listed" >
                    <option value="">--Select Market-- </option>
                    <%
                    if @cities && @cities.length >0
                     @cities.each do |city|
                     
                     %>
                       <option value="<%= city.Id %>" <% if @market_listed && @market_listed.to_i== city.Id.to_i %>selected<% end %> ><%= city.City %></option>
                     <% end end %>	
                    </select>
                    </div>
                    <div class="col-sm-12 col-md-1">  
                      <button data-bs-toggle="button" class="btn btn-circle btn-default" onclick="search_process_listed();">
                        <i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-3">  
                    <a href="<%=root_url%>stock_return_list/refresh_stock_return_list">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                     
                  <% end %>
                     
                       <div class="row " style="margin-top:10px;">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>stock_return"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Stock Return</button> </a>
                      </div>
                      <div class="col-sm-12 col-md-9 ">  
                    <% if @stock_receipt_list.length>0 %>
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline " style="float:right;">CSV</button> </a>
                      <% end %>
                      </div>
                      </div>
											<div class="table-scrollable">
												<table class="table">
													<thead>
														<tr>
															<th>S.No</th>
															<th>Market Name</th>
                              <th>WD Name </th>
															<th>Activity Name</th>
                             
															<th>Brand Variant</th>
                            
                              <th>Date of Pickup</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                              <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @stock_receipt_list.length>0 %>
                            <% @stock_receipt_list.each do |stock| %>

                            <%
                            cityname= ""
                            cityobj = get_city_list(stock.Ref_city_id)
                            if cityobj
                              cityname = cityobj.City
                            end

                            wdname= ""
                            wdobj=get_wd_list(stock.Ref_Wd_Id)
                            if wdobj
                            wdname=wdobj.WDName
                            end

                            
                            activitname = ""
                            activityobj=get_activity_list(stock.Ref_Activity_id)
                            if activityobj
                              activitname =activityobj.activity_name
                            end

                            brandvariant = ""
                            brandvariantobj=get_brand_list(stock.Ref_Brand_id)
                            if brandvariantobj
                              brandvariant =brandvariantobj.Variant_Name
                            end

                            variant = ""
                            variantobj=get_variant_list(stock.Brand_Variant)
                            if variantobj
                              variant =variantobj.vt_description
                            end

                            %>


														<tr>
															<td><%= i %></td>
                              <td><%= cityname %></td>
                              <td><%=wdname%></td>
                              <td><%=activitname%></td>
                              <td><%=variant%></td>
                              <td><%=formatted_date(stock.Date_of_pickup)%></td>
                               <td>
                              <a href="<%= root_url %>stock_return/<%=stock.Id%>" class="tblEditBtn">
                                    <i class="fa fa-pencil"></i>
                                  </a>
                              <a class="tblDelBtn" id="del<%=stock.Id%>" onclick="alertChecked('<%=stock.Id%>')" rel="<%= root_url %>stock_return_list/<%=stock.Id%>/delete">
                                <i class="fa fa-trash-o"></i>
                              </a>
                            
                            </td>
														</tr>
                            <% i += 1 %>
                            <% end %>
                          <% else %>
                            <tr>
                              <td colspan="6">No record(s) found.</td>
                            </tr>
                          <% end %>
													
													</tbody>
												</table>
											</div>
                     
                   <div class="col-md-12 text-center"><%= will_paginate @stock_receipt_list %></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

