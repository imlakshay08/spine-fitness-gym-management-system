<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper" >
    <div class="page-content" >
           
	<div class="page-bar">
	<div class="page-title-breadcrumb">
		<div class=" pull-left">
			<div class="page-title">Add Stock Inventory</div>
		</div>
		<%= render "layouts/breadcrumbs" %>
	</div>
</div>		
	<div class="row">
	<div class="col-md-12 col-sm-12">
		<div class="card card-box" >
			
			<div class="card-body">
			<div class="row">
	       <div class="col-md-12 col-sm-12">
		<a href="<%=root_url%>stock_inventory" class="float-right">	<button type="button" class="btn btn-circle btn-info "><i class="fa fa-arrow-left"></i> Back to list</button> </a>
		</div>
		</div>
		<% if flash[:error] %>
             <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
             <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
            <%= flash[:error] %>
            </div>
        <% end %>

			<%= form_tag({action: 'create'}, multipart: :true, id: :myforms, class: "form-horizontal") do  %>
             			<input type="hidden"  id="rootXPath" value="<%=root_url%>"/>
			  <input type="hidden" name="mid" id="mid" value="<% if @stockin %><%=@stockin.id%><% end %>"/>         
			<input type="hidden" name="cur_si_entry_no" id="cur_si_entry_no" value="<% if @stockin %><%=@stockin.si_entry_no%><% end %>"/>

					<div class="form-body">
						
					<div class="form-group row">
					<label class="col-md-2">Transaction No.
						<span class="required"> * </span>
					</label>
					<div class="col-md-4">
					<input name="si_entry_no" id="si_entry_no"  type="text"  placeholder="Enter Transaction No."
					autocomplete="off" maxlength="10" class="form-control" readonly required value="<% if @stockin%><%=@stockin.si_entry_no%><% else %><%=@Lastcode%><% end %>"/> 
					</div>
					<label class="col-md-2">Stock Name
					<span class="required"> * </span>
				</label>
				<div class="col-md-4">
						<select class="form-select select-height " required name="si_stock_id" id="si_stock_id">
                    <option value="">Select...</option>
                    <%
                        if @StockList && @StockList.length>0
                            @StockList.each do |stock|
                    %>
                    <option value="<%=stock.id%>" <% if @stockin && @stockin.si_stock_id.to_i == stock.id.to_i %>selected<% elsif session[:sess_si_stock_id].to_s==stock.id.to_i%>selected<% end %>><%=stock.sl_name%>(<%=stock.sl_descp%>)</option>
                    <%
                    end
                    end
                    %>
                </select>				
				</div>
					</div>
				
						<div class="form-group row">
				
						<label class=" col-md-2">Transaction Type
					<span class="required"> * </span>
						</label>
						<div class="col-md-4">
						<select class="form-select select-height " required name="si_trans_type" id="si_trans_type">
							<option value="">Select...</option>
							<option value="IN" <% if @stockin && @stockin.si_trans_type.to_s =='IN'%>selected="selected"<% end %>>In</option>
							<option value="OUT"<% if @stockin && @stockin.si_trans_type.to_s =='OUT'%>selected="selected"<% end %>>Out</option>
						</select>
						</div>
					</div>

		               <div class="form-group row">
						<label class=" col-md-2">Quantity
					<span class="required"> * </span>
						</label>
						<div class="col-md-4">
						<input name="si_quantity" id="si_quantity" type="text" maxlength="5" placeholder="Enter Quantity"onkeypress="return isNumberMyKeys(event);" class="form-control" value="<% if @stockin%><%=@stockin.si_quantity%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['si_quantity'] %><% end %>" />
						</div>
						<label class=" col-md-2">Remarks
						</label>
						<div class="col-md-4">
						<input name="si_remarks" id="si_remarks" type="text" maxlength="25" placeholder="Enter Remarks(Optional)" class="form-control" value="<% if @stockin%><%=@stockin.si_remarks%><% elsif session[:postedpamams] != nil %><%= session[:postedpamams]['si_remarks'] %><% end %>" />
						</div>
					</div>

							<div class="form-group form-button text-center  m-b-20" style="margin-top: 50px;">
							<button type="submit"
							class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 m-r-20 btn-circle btn-primary">SUBMIT</button>
								<div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner is-active process_loader" style="display:none;"></div>
							<a href="<%=root_url%>stock_inventory">	<button type="button" class="mdl-button mdl-js-button mdl-button--raised mdl-js-ripple-effect m-b-10 btn-circle btn-danger">Quit</button> </a>
							</div>
					</div>
				</form>
				<% end %>
			</div>
		</div>
	</div>
</div>
					
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>