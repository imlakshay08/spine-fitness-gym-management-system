<div class="page-wrapper">
<%= render "layouts/header" %>
<!-- start page container -->
		<div class="page-container">
		<%= render "layouts/sidebar" %>
 <div class="page-content-wrapper">
    <div class="page-content" >
           
    <div class="page-bar">
						<div class="page-title-breadcrumb">
							<div class=" pull-left">
								<div class="page-title">Stock Inventory List</div>
							</div>
							<%= render "layouts/breadcrumbs" %>
						</div>
            
					</div>
       
					<div class="row">
						<div class="col-md-12">
							<div class="row">
								<div class="col-sm-12">
									<div class="card">
								
										<div class="card-body ">
                    <% if flash[:error] %>
                    <div class="alert <% if session[:isErrorhandled].to_i >0 %>alert-danger<% else %>alert-success<% end %>" style="width:900px;" id="successXMessage">
                      <span class="closebtn" onclick="this.parentElement.style.display='none';">&times;</span>
                      <%= flash[:error] %>
                    </div>
                   <% end %>
                    <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <%= form_tag({:action=>'index'} ,method: :get ,:multipart=>true,:id=>'myForms') do  %>
                                        <input type="hidden"  id="rootXPath" value="<%=root_url%>"/>                                        
                      <input type="hidden" name="server_request" id="server_request" value="Y"/>
                    <div class="row m-b-10">
                   <label class="col-sm-12 col-md-1">Search</label>
                    <div class="col-sm-12 col-md-4">  <input type="text" class="form-control" name="stock_inventory" id="stock_inventory"  autocomplete="off" placeholder=""  value="<% if @stock_inventory_search %><%=@stock_inventory_search%><% end %>"/></div>
                   <label class="col-sm-12 col-md-1">Course </label>
                    <div class="col-sm-12 col-md-3">  
                    	<select class="form-select select-height"  name="stock_search" id="stock_search">
                  <option value="">Select...</option>
                   <%
                        if @StockList && @StockList.length>0
                            @StockList.each do |stock|
                    %>
                    <option value="<%=stock.id%>" <% if @stock_search && @stock_search.to_i == stock.id.to_i %>selected="selected"<% end %>><%=stock.sl_name%></option>
                    <%
                    end
                    end
                    %>
                </select>

                    </div>
                    
                    <div class="col-sm-12 col-md-1 no_loader">  
                    <button data-bs-toggle="button" onclick="filter_stock_inventory();" class="btn btn-circle btn-default" ><i class="fa fa-search"></i>
											</button>
                    </div>
                    <div class="col-sm-12 col-md-1 show_loader hidden">
                    <div class="mdl-spinner mdl-spinner--single-color mdl-js-spinner  " >
                      <img src="<%=root_url%>/images/spining_loader.gif" width="30px">
                    </div>
                  </div>
                    <div class="col-sm-12 col-md-2">  
                    <a href="<%=root_url%>subject_list/referesh_subject_list" class="float-right">
                    <button type="button" class="btn btn-circle btn-info "><i class="fa fa-refresh"></i> Reset</button> </a>
                    </div>
                    </div>  

                      <%end%>
                      <div class="row">
                      <div class="col-sm-12 col-md-3">  
                      <a href="<%=root_url%>stock_inventory/add_stock_inventory"  class="">
                      <button type="button" class="btn btn-circle btn-success"><i class="fa fa-plus"></i> Add Stock Transaction</button> </a>
                      </div> 
                      <div class="col-sm-12 col-md-9 hidden">  
                      <a href="javascript:;" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for excel download">
                      <button type="button" class="btn dark btn-outline m-b-10" style="float:right;">CSV</button> </a>

                      </div>
                      <div class="col-sm-12 col-md-9 ">  
                      <a href="<%=root_url%>subject_list/1_prt_subject_list.pdf" target="_blank" class="float-right" data-placement="bottom" data-toggle="tooltip" title="" data-original-title="Click for pdf download">
                      <button type="button" class="btn dark btn-outline m-b-10 " style="float:right;">PDF</button> </a>
                      </div>
                      </div>
											
												<table 
                        class="table table-striped table-bordered table-hover "
                        id="example4">
													<thead>
														<tr>
															<th>S.No</th>
                              <th>Transaction No.</th>
                              <th>Transaction Date</th>
                            	<th>Stock Name</th>
                              <th>Transaction Type</th>
                              <th>Quantity</th>
                              <th>Action</th>
														</tr>
													</thead>
													<tbody>
                                         <% pagestart = params[:page].present? ? params[:page].to_i : 1 %>
                          <% i = pagestart <= 1 ? 1 : ((pagestart - 1) * 10) + 1 %>

                          <% if @stock_inventory && @stock_inventory.length>0 %>
                            <% @stock_inventory.each do |stockin| %>    
                              <%       
														stockobj = get_stock_detail(stockin.si_stock_id)
                            if stockobj
                               stockname = stockobj.sl_name
                               stockdescp = stockobj.sl_descp
                            end
                            %>
														<tr  class="odd gradeX">
															<td><%= i %></td>
                            	<td><%= stockin.si_entry_no %></td>
                            	<td><%= formatted_date(stockin.si_entry_date) %></td>
                               <td> <%= stockname %>(<%=stockdescp%>) </td>
                            	<td><%= stockin.si_trans_type %></td>
                              <td><%= stockin.si_quantity %></td>
                              <td>
                              <a href="<%= root_url %>stock_inventory/add_stock_inventory/<%= stockin.id %>"
                                class="tblEditBtn">
                                <i class="fa fa-pencil"></i>
                              </a>
                              <a class="tblDelBtn" onclick="alertChecked('<%= root_url %>stock_inventory/<%= stockin.id %>/deletes')">
                                <i class="fa fa-trash-o"></i>
                              </a>
                            </td>
														</tr>
                          <% i += 1 %>
                            <% end %>
                            <% end %>
													</tbody>
												</table>
											
                     
                    <div class="col-md-12 text-center"></div>
                    
										</div>
									</div>
								</div>

                </div>
                </div>
                </div>
        
			</div>
	 	</div>	 

    </div>
	<!-- End page container -->
</div>

